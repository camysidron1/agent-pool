# Clone directories (managed by agent-pool)
# Catch-all for any prefix pattern: <prefix>-NN/
*-[0-9][0-9]/

# Per-project state files
pool-*.json
tasks-*.json

# Legacy state files
pool.json
tasks.json

# Lock files
*.lock/

# Runtime data directories
approvals/
docs/

# Temp files
*.tmp

# Task-finished marker files
.task-finished-*

# SQLite database (runtime data)
agent-pool.db
agent-pool.db-shm
agent-pool.db-wal

# Runtime data directory
data/

# Agent mailbox files
.mailbox

# cmux layout
layout.json

# Project config (user-specific)
projects.json

# Claude credentials
.claude/

# Agent-runner injected files (symlinks in clones)
agent-docs
shared-docs
CLAUDE.md
.claude/commands/finish.md

# v2 build artifacts
v2/node_modules/
v2/dist/
v2/bun.lock

# Runtime artifacts (daemon state, event log, SQLite)
apd.pid
data.db
events.jsonl
loops/*.log

# Personal one-off bootstrap scripts
.initiate-driver-*.sh
