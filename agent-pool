#!/usr/bin/env bash
set -euo pipefail

TOOL_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
DATA_DIR="${DATA_DIR:-${POOL_DIR:-$HOME/.agent-pool}}"
export POOL_DIR="$DATA_DIR"  # backward compat for child processes

PROJECTS_JSON="$DATA_DIR/projects.json"
RUNNER_SCRIPT="$TOOL_DIR/agent-runner.sh"

# Source library modules
source "$TOOL_DIR/lib/project.sh"
source "$TOOL_DIR/lib/pool.sh"
source "$TOOL_DIR/lib/tasks.sh"

# Source command modules
for cmd_file in "$TOOL_DIR"/lib/cmd/*.sh; do
  source "$cmd_file"
done

# --- main ---

# Parse global flags before command
PROJECT=""
while [[ $# -gt 0 ]]; do
  case $1 in
    -p|--project) PROJECT="$2"; shift 2 ;;
    *) break ;;
  esac
done

cmd="${1:-help}"
shift || true

# Parse -p/--project after command too (for convenience)
REMAINING_ARGS=()
while [[ $# -gt 0 ]]; do
  case $1 in
    -p|--project) PROJECT="$2"; shift 2 ;;
    *) REMAINING_ARGS+=("$1"); shift ;;
  esac
done
set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

# Auto-migrate before any command
auto_migrate

case "$cmd" in
  project)  cmd_project "$@" ;;
  init)     cmd_init "$@" ;;
  launch)   cmd_launch "$@" ;;
  status)   cmd_status "$@" ;;
  add)      cmd_add "$@" ;;
  tasks)    cmd_tasks "$@" ;;
  unblock)  cmd_unblock "$@" ;;
  backlog)  cmd_backlog "$@" ;;
  activate)  cmd_activate "$@" ;;
  set-status) cmd_set_status "$@" ;;
  approvals) cmd_approvals "$@" ;;
  approve)   cmd_approve "$@" ;;
  deny)      cmd_deny "$@" ;;
  watch)     cmd_watch "$@" ;;
  docs)      cmd_docs "$@" ;;
  refresh)   cmd_refresh "$@" ;;
  release)  cmd_release "$@" ;;
  restart)  cmd_restart "$@" ;;
  destroy)  cmd_destroy "$@" ;;
  review)   cmd_review "$@" ;;
  start)    cmd_start "$@" ;;
  help|--help|-h) cmd_help ;;
  *) echo "Unknown command: $cmd"; cmd_help; exit 1 ;;
esac
