{
  "name": "agent-pool-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.23",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bunx --package typescript tsc -p tsconfig.json --noEmit --pretty false",
    "test": "bun test apps packages",
    "test:browser": "bun apps/web/tests/browser-smoke.ts",
    "images:build-push": "bun run deploy/images/build-and-push.ts",
    "infra:fmt": "terraform -chdir=deploy/terraform/aws fmt -recursive",
    "infra:validate": "terraform -chdir=deploy/terraform/aws validate",
    "k8s:render:aws": "kubectl kustomize deploy/kubernetes",
    "k8s:deploy:aws": "kubectl apply -k deploy/kubernetes",
    "smoke:compose": "bun run deploy/compose/smoke-compose.ts",
    "smoke:kubernetes": "bun run deploy/kubernetes/smoke-kubernetes.ts",
    "smoke:e2b": "bun run deploy/compose/e2b-smoke.ts",
    "demo:evidence": "bun run deploy/kubernetes/manual-demo-evidence.ts"
  }
}
