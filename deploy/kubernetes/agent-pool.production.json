    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "agent-pool-web",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-web",
          "app.kubernetes.io/component": "web",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
