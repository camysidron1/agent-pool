    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "agent-pool-rabbitmq",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-rabbitmq",
          "app.kubernetes.io/component": "queue",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "selector": {
          "app.kubernetes.io/name": "agent-pool-rabbitmq",
          "app.kubernetes.io/component": "queue"
        },
        "ports": [
          {
            "name": "amqp",
            "port": 5672,
            "targetPort": 5672
          },
          {
            "name": "management",
            "port": 15672,
            "targetPort": 15672
          }
        ]
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "StatefulSet",
      "metadata": {
        "name": "agent-pool-rabbitmq",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-rabbitmq",
          "app.kubernetes.io/component": "queue",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "serviceName": "agent-pool-rabbitmq",
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "agent-pool-rabbitmq",
            "app.kubernetes.io/component": "queue"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "agent-pool-rabbitmq",
              "app.kubernetes.io/component": "queue",
              "app.kubernetes.io/part-of": "agent-pool"
            }
          },
          "spec": {
            "containers": [
              {
                "name": "rabbitmq",
                "image": "rabbitmq:3.13-management-alpine",
                "ports": [
                  {
                    "name": "amqp",
                    "containerPort": 5672
                  },
                  {
                    "name": "management",
                    "containerPort": 15672
                  }
                ],
                "env": [
                  {
                    "name": "RABBITMQ_DEFAULT_USER",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "agent-pool-secrets",
                        "key": "RABBITMQ_DEFAULT_USER"
                      }
                    }
                  },
                  {
                    "name": "RABBITMQ_DEFAULT_PASS",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "agent-pool-secrets",
                        "key": "RABBITMQ_DEFAULT_PASS"
                      }
                    }
                  }
                ],
                "volumeMounts": [
                  {
                    "name": "rabbitmq-data",
                    "mountPath": "/var/lib/rabbitmq"
                  }
                ],
                "readinessProbe": {
                  "exec": {
                    "command": [
                      "rabbitmq-diagnostics",
                      "-q",
                      "ping"
                    ]
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                }
              }
            ],
            "volumes": [
              {
                "name": "rabbitmq-data",
                "persistentVolumeClaim": {
                  "claimName": "agent-pool-rabbitmq-data"
                }
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "agent-pool-blob",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-blob",
          "app.kubernetes.io/component": "blob-storage",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "selector": {
          "app.kubernetes.io/name": "agent-pool-blob",
          "app.kubernetes.io/component": "blob-storage"
        },
        "ports": [
          {
            "name": "s3",
            "port": 9000,
            "targetPort": 9000
          },
          {
            "name": "console",
            "port": 9001,
            "targetPort": 9001
          }
        ]
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "StatefulSet",
      "metadata": {
        "name": "agent-pool-blob",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-blob",
          "app.kubernetes.io/component": "blob-storage",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "serviceName": "agent-pool-blob",
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "agent-pool-blob",
            "app.kubernetes.io/component": "blob-storage"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "agent-pool-blob",
              "app.kubernetes.io/component": "blob-storage",
              "app.kubernetes.io/part-of": "agent-pool"
            }
          },
          "spec": {
            "containers": [
              {
                "name": "minio",
                "image": "minio/minio:RELEASE.2024-10-13T13-34-11Z",
                "args": [
                  "server",
                  "/data",
                  "--console-address",
                  ":9001"
                ],
                "ports": [
                  {
                    "name": "s3",
                    "containerPort": 9000
                  },
                  {
                    "name": "console",
                    "containerPort": 9001
                  }
                ],
                "env": [
                  {
                    "name": "MINIO_ROOT_USER",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "agent-pool-secrets",
                        "key": "MINIO_ROOT_USER"
                      }
                    }
                  },
                  {
                    "name": "MINIO_ROOT_PASSWORD",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "agent-pool-secrets",
                        "key": "MINIO_ROOT_PASSWORD"
                      }
                    }
                  }
                ],
                "volumeMounts": [
                  {
                    "name": "blob-data",
                    "mountPath": "/data"
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/minio/health/ready",
                    "port": 9000
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                }
              }
            ],
            "volumes": [
              {
                "name": "blob-data",
                "persistentVolumeClaim": {
                  "claimName": "agent-pool-blob-data"
                }
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "batch/v1",
      "kind": "Job",
      "metadata": {
        "name": "agent-pool-blob-bootstrap",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-blob-bootstrap",
          "app.kubernetes.io/component": "blob-storage",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "agent-pool-blob-bootstrap",
              "app.kubernetes.io/component": "blob-storage",
              "app.kubernetes.io/part-of": "agent-pool"
            }
          },
          "spec": {
            "restartPolicy": "OnFailure",
            "containers": [
              {
                "name": "mc",
                "image": "minio/mc:RELEASE.2024-10-08T09-37-26Z",
                "command": [
                  "sh",
                  "-c"
                ],
                "args": [
                  "mc alias set agent-pool http://agent-pool-blob.agent-pool.svc.cluster.local:9000 \"$MINIO_ROOT_USER\" \"$MINIO_ROOT_PASSWORD\" && mc mb --ignore-existing agent-pool/agent-pool-artifacts"
                ],
                "env": [
                  {
                    "name": "MINIO_ROOT_USER",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "agent-pool-secrets",
                        "key": "MINIO_ROOT_USER"
                      }
                    }
                  },
                  {
                    "name": "MINIO_ROOT_PASSWORD",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "agent-pool-secrets",
                        "key": "MINIO_ROOT_PASSWORD"
                      }
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "agent-pool-prometheus",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-prometheus",
          "app.kubernetes.io/component": "metrics",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "selector": {
          "app.kubernetes.io/name": "agent-pool-prometheus",
          "app.kubernetes.io/component": "metrics"
        },
        "ports": [
          {
            "name": "http",
            "port": 9090,
            "targetPort": 9090
          }
        ]
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "agent-pool-prometheus",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-prometheus",
          "app.kubernetes.io/component": "metrics",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "agent-pool-prometheus",
            "app.kubernetes.io/component": "metrics"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "agent-pool-prometheus",
              "app.kubernetes.io/component": "metrics",
              "app.kubernetes.io/part-of": "agent-pool"
            }
          },
          "spec": {
            "securityContext": {
              "fsGroup": 65534,
              "fsGroupChangePolicy": "OnRootMismatch"
            },
            "containers": [
              {
                "name": "prometheus",
                "image": "prom/prometheus:v2.55.1",
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "runAsNonRoot": true,
                  "runAsUser": 65534
                },
                "args": [
                  "--config.file=/etc/prometheus/prometheus.yml",
                  "--storage.tsdb.path=/prometheus",
                  "--storage.tsdb.retention.time=15d"
                ],
                "ports": [
                  {
                    "name": "http",
                    "containerPort": 9090
                  }
                ],
                "volumeMounts": [
                  {
                    "name": "prometheus-config",
                    "mountPath": "/etc/prometheus",
                    "readOnly": true
                  },
                  {
                    "name": "prometheus-data",
                    "mountPath": "/prometheus"
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/-/healthy",
                    "port": 9090
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 10
                }
              }
            ],
            "volumes": [
              {
                "name": "prometheus-config",
                "configMap": {
                  "name": "agent-pool-prometheus-config"
                }
              },
              {
                "name": "prometheus-data",
                "persistentVolumeClaim": {
                  "claimName": "agent-pool-prometheus-data"
                }
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "batch/v1",
      "kind": "CronJob",
      "metadata": {
        "name": "agent-pool-sqlite-backup",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool-sqlite-backup",
          "app.kubernetes.io/component": "backup",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "schedule": "17 3 * * *",
        "successfulJobsHistoryLimit": 3,
        "failedJobsHistoryLimit": 3,
        "jobTemplate": {
          "spec": {
            "template": {
              "metadata": {
                "labels": {
                  "app.kubernetes.io/name": "agent-pool-sqlite-backup",
                  "app.kubernetes.io/component": "backup",
                  "app.kubernetes.io/part-of": "agent-pool"
                }
              },
              "spec": {
                "restartPolicy": "OnFailure",
                "containers": [
                  {
                    "name": "backup",
                    "image": "busybox:1.36",
                    "command": [
                      "sh",
                      "-c"
                    ],
                    "args": [
                      "stamp=\"$(date +%Y%m%d%H%M%S)\"; cp /sqlite/web-sandbox.db \"/backups/web-sandbox-${stamp}.db\"; find /backups -name 'web-sandbox-*.db' -mtime +14 -delete"
                    ],
                    "volumeMounts": [
                      {
                        "name": "sqlite-data",
                        "mountPath": "/sqlite",
                        "readOnly": true
                      },
                      {
                        "name": "sqlite-backups",
                        "mountPath": "/backups"
                      }
                    ]
                  }
                ],
                "volumes": [
                  {
                    "name": "sqlite-data",
                    "persistentVolumeClaim": {
                      "claimName": "agent-pool-sqlite",
                      "readOnly": true
                    }
                  },
                  {
                    "name": "sqlite-backups",
                    "persistentVolumeClaim": {
                      "claimName": "agent-pool-sqlite-backups"
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "Ingress",
      "metadata": {
        "name": "agent-pool",
        "namespace": "agent-pool",
        "labels": {
          "app.kubernetes.io/name": "agent-pool",
          "app.kubernetes.io/part-of": "agent-pool"
        }
      },
      "spec": {
        "rules": [
          {
            "host": "agent-pool.example.com",
            "http": {
              "paths": [
                {
                  "path": "/api",
                  "pathType": "Prefix",
                  "backend": {
                    "service": {
                      "name": "agent-pool-api",
                      "port": {
                        "number": 3000
                      }
                    }
                  }
                },
                {
                  "path": "/",
                  "pathType": "Prefix",
                  "backend": {
                    "service": {
                      "name": "agent-pool-web",
                      "port": {
                        "number": 8080
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
