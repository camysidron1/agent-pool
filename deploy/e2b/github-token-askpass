#!/usr/bin/env sh
set -eu

env_name="${AGENT_POOL_GITHUB_TOKEN_ENV:-GITHUB_TOKEN}"
case "$env_name" in
  "" | *[!A-Z0-9_]* | [0-9]*)
    exit 1
    ;;
esac

prompt="${1:-}"
case "$prompt" in
  *Username* | *username*)
    printf '%s\n' "${GITHUB_USERNAME:-x-access-token}"
    exit 0
    ;;
esac

token="$(printenv "$env_name" || true)"
if [ -z "$token" ]; then
  exit 1
fi

printf '%s\n' "$token"
