{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@agent-pool/config": ["packages/config/src/index.ts"],
      "@agent-pool/shared": ["packages/shared/src/index.ts"]
    }
  },
  "include": ["apps/api/src/**/*.ts", "packages/config/src/**/*.ts", "packages/shared/src/**/*.ts"]
}
