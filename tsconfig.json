{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@agent-pool/auth": ["packages/auth/src/index.ts"],
      "@agent-pool/config": ["packages/config/src/index.ts"],
      "@agent-pool/db": ["packages/db/src/index.ts"],
      "@agent-pool/queue": ["packages/queue/src/index.ts"],
      "@agent-pool/runtime": ["packages/runtime/src/index.ts"],
      "@agent-pool/session-bridge": ["packages/session-bridge/src/index.ts"],
      "@agent-pool/shared": ["packages/shared/src/index.ts"],
      "@agent-pool/storage": ["packages/storage/src/index.ts"]
    }
  },
  "include": [
    "apps/api/src/**/*.ts",
    "apps/orchestrator/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/vite.config.ts",
    "packages/auth/src/**/*.ts",
    "packages/config/src/**/*.ts",
    "packages/db/src/**/*.ts",
    "packages/queue/src/**/*.ts",
    "packages/runtime/src/**/*.ts",
    "packages/session-bridge/src/**/*.ts",
    "packages/shared/src/**/*.ts",
    "packages/storage/src/**/*.ts"
  ]
}
