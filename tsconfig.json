{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@agent-pool/config": ["packages/config/src/index.ts"],
      "@agent-pool/shared": ["packages/shared/src/index.ts"]
    }
  },
  "include": [
    "apps/api/src/**/*.ts",
    "apps/orchestrator/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/vite.config.ts",
    "packages/config/src/**/*.ts",
    "packages/shared/src/**/*.ts"
  ]
}
