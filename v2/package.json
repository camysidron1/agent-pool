{
  "name": "@agent-pool/tui",
  "version": "2.0.0",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "src",
    "commands",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./ag-ui": {
      "types": "./src/ag-ui.ts",
      "import": "./src/ag-ui.ts",
      "default": "./src/ag-ui.ts"
    }
  },
  "bin": {
    "agent-pool": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bun test tests/e2e"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@sinclair/typebox": "^0.34.0",
    "commander": "^12.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0"
  }
}
